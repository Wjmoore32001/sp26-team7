### Create ClassTemplate 1 for instructor 1

POST http://localhost:8080/classTemplates HTTP/1.1
Content-Type: application/json

{
  "title": "Intro Yoga",
  "classType": "YOGA",
  "intensity": "MEDIUM",
  "duration": 60,
  "price": 19.99,
  "description": "Beginner yoga class",
  "instructor": {
    "userId": 1
  }
}


### Create ClassTemplate 2 for instructor 1

POST http://localhost:8080/classTemplates HTTP/1.1
Content-Type: application/json

{
  "title": "Morning Burn",
  "classType": "CARDIO",
  "intensity": "HIGH",
  "duration": 45,
  "price": 24.99,
  "description": "Fast-paced cardio workout",
  "instructor": {
    "userId": 1
  }
}


### Create ClassTemplate 3 for instructor 2

POST http://localhost:8080/classTemplates HTTP/1.1
Content-Type: application/json

{
  "title": "Spin Intro",
  "classType": "CYCLING",
  "intensity": "MEDIUM",
  "duration": 50,
  "price": 22.50,
  "description": "Introductory cycling session",
  "instructor": {
    "userId": 2
  }
}


### Get all class templates

GET http://localhost:8080/classTemplates HTTP/1.1


### Get class template with templateId 1

GET http://localhost:8080/classTemplates/1 HTTP/1.1


### Get class template with templateId 2

GET http://localhost:8080/classTemplates/2 HTTP/1.1


### Get all templates for instructor 1

GET http://localhost:8080/classTemplates/instructor/1 HTTP/1.1


### Get all templates for instructor 2

GET http://localhost:8080/classTemplates/instructor/2 HTTP/1.1


### Update class template 2 description only

PUT http://localhost:8080/classTemplates/2 HTTP/1.1
Content-Type: application/json

{
  "description": "Updated cardio workout description"
}


### Verify class template 2 was updated

GET http://localhost:8080/classTemplates/2 HTTP/1.1


### Delete class template 3

DELETE http://localhost:8080/classTemplates/3 HTTP/1.1


### Verify class template 3 is gone

GET http://localhost:8080/classTemplates/3 HTTP/1.1


### Verify templates for instructor 2 after delete

GET http://localhost:8080/classTemplates/instructor/2 HTTP/1.1


### Verify all remaining class templates

GET http://localhost:8080/classTemplates HTTP/1.1
